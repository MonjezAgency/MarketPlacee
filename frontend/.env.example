# --- FRONTEND CONFIG ---
# (Prefix with NEXT_PUBLIC_ to make it accessible to the client)

# URL of the deployed backend API (e.g. Render, Railway)
# Production: https://api.yourdomain.com | Development: http://localhost:3001
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- AUTH CONFIG (NEXTAUTH.JS) ---
# Canonical URL of your frontend (Vercel)
# Production: https://your-app.vercel.app | Development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# Secret used to salt/hash sessions (must match your JWT_SECRET)
NEXTAUTH_SECRET="your_nextauth_secret_here"

# --- EXTERNAL SERVICES (CLIENT-SIDE) ---
# Stripe Public Key (safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- SECURITY ---
# Secret for seeding the admin account (frontend/src/lib/auth.tsx)
NEXT_PUBLIC_SEED_ADMIN_SECRET="atlantis_seed_2025_secure"
