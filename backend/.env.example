# --- DATABASE CONFIG ---
# Connection string for PostgreSQL (e.g. Supabase, AWS RDS, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace_db?schema=public"

# --- SERVER CONFIG ---
# The port the backend will listen on (Render/Railway typically provides this)
PORT=3001
# Set to 'production' in deployed environments
NODE_ENV=development

# --- AUTH CONFIG ---
# Secret for signing JWT access tokens (use a long random string)
JWT_SECRET="your_jwt_secret_here"
# NextAuth config (keep same as frontend if shared)
NEXTAUTH_SECRET="your_nextauth_secret_here"
# Canonical frontend URL (e.g. https://your-app.vercel.app)
FRONTEND_URL="http://localhost:3000"

# --- EMAIL CONFIG (SMTP) ---
EMAIL_HOST="smtp.hostinger.com"
EMAIL_PORT=465
EMAIL_USER="Info@atlantisfmcg.com"
EMAIL_PASS="AliDawara@22"

# --- EXTERNAL SERVICES ---
# Stripe Secret Key (for payments)
STRIPE_API_KEY="sk_test_..."
# AWS S3 (for file uploads)
AWS_S3_BUCKET="your-bucket-name"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="secret..."

# OpenAI / AI Providers
OPENAI_API_KEY="sk-..."
OPENROUTER_API_KEY="sk-or-..."

# --- SECURITY ---
# Secret for seeding the admin account (backend/src/auth/auth.controller.ts)
SEED_ADMIN_SECRET="atlantis_seed_2025_secure"
