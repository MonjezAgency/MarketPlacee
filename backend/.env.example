# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/marketplace_db?schema=public

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3005
NODE_ENV=development

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_64_chars_minimum_random_string_here
JWT_REFRESH_SECRET=change_me_different_from_jwt_secret_64_chars
JWT_COOKIE_NAME=token

# ─── Encryption ──────────────────────────────────────────────────────────────
# Used to encrypt IBAN, Swift, 2FA secrets — must be exactly 32 chars
ENCRYPTION_KEY=change_me_exactly_32_characters!!

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ─── Platform ────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=5
DEFAULT_CURRENCY=eur
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://marketpl7ce.vercel.app

# ─── Email (Hostinger SMTP) ──────────────────────────────────────────────────
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=Info@atlantisfmcg.com
EMAIL_PASS=your_smtp_password
EMAIL_FROM=Atlantis Marketplace <Info@atlantisfmcg.com>

# ─── Email Fallback (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=onboarding@resend.dev

# ─── Supabase Storage (KYC Documents) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Seed ────────────────────────────────────────────────────────────────────
SEED_ADMIN_SECRET=your_seed_secret

# ─── Optional ────────────────────────────────────────────────────────────────
AWS_S3_BUCKET=
OPENROUTER_API_KEY=
