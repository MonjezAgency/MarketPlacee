# .env.example (Backend)
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/db

# Auth
JWT_SECRET=your_jwt_secret_must_match_frontend
JWT_REFRESH_SECRET=your_refresh_secret
JWT_COOKIE_NAME=token

# Email (Hostinger SMTP)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=Info@atlantisfmcg.com
EMAIL_PASS=your_smtp_password
EMAIL_FROM=Atlantis Marketplace <Info@atlantisfmcg.com>

# Email Fallback (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=onboarding@resend.dev

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://marketpl7ce.vercel.app
FRONTEND_URL=http://localhost:3000
